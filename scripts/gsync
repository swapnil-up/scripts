#!/usr/bin/env bash
set -euo pipefail

GITHUB_DIR="$HOME/github"
TIMEOUT=30
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

sync_count=0
skip_count=0
error_count=0

echo -e "${CYAN}gsync — multi-repo git sync${NC}"

for dir in "$GITHUB_DIR"/*/; do
  repo=$(basename "$dir")
  [ -d "$dir/.git" ] || { skip_count=$((skip_count + 1)); continue; }

  remote_url=$(git -C "$dir" remote get-url origin 2>/dev/null || true)
  [[ "$remote_url" =~ github.com[/:]swapnil-up/ ]] || { skip_count=$((skip_count + 1)); continue; }

  echo -e "\n${CYAN}━━━ $repo ━━━${NC}"
  branch=$(git -C "$dir" branch --show-current 2>/dev/null || echo "HEAD")
  echo -e "  branch: ${YELLOW}$branch${NC}"

  stash_count_before=$(git -C "$dir" stash list | wc -l)
  git -C "$dir" stash push -u -m "gsync auto-stash $(date '+%Y-%m-%d %H:%M')" 2>/dev/null || true
  stash_count_after=$(git -C "$dir" stash list | wc -l)
  did_stash=false
  [ "$stash_count_after" -gt "$stash_count_before" ] && did_stash=true

  echo -e "  ${YELLOW}→ pulling with rebase${NC}"
  if ! timeout $TIMEOUT git -C "$dir" pull --rebase origin "$branch" 2>&1 | sed 's/^/    /'; then
    echo -e "  ${RED}✗ pull/rebase failed or timed out${NC}"
    error_count=$((error_count + 1))
    continue
  fi

  echo -e "  ${YELLOW}→ pushing${NC}"
  if ! timeout $TIMEOUT git -C "$dir" push origin "$branch" 2>&1 | sed 's/^/    /'; then
    echo -e "  ${RED}✗ push failed or timed out${NC}"
    error_count=$((error_count + 1))
    continue
  fi

  if [ "$did_stash" = true ]; then
    echo -e "  ${YELLOW}→ restoring stash${NC}"
    if ! git -C "$dir" stash pop 2>&1 | sed 's/^/    /'; then
      echo -e "  ${RED}✗ stash pop had conflicts — resolve manually in $repo${NC}"
      error_count=$((error_count + 1))
      continue
    fi
  fi

  echo -e "  ${GREEN}✓ synced${NC}"
  sync_count=$((sync_count + 1))
done

echo -e "\n${CYAN}═══════════════════════${NC}"
echo -e "  ${GREEN}$sync_count synced${NC}  ${YELLOW}$skip_count skipped${NC}  ${RED}$error_count errors${NC}"
